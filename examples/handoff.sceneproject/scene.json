{
  "version": 1,
  "name": "Video Handoff",
  "description": "Timed video playback: one sequence's hold tracks drive each video's 'playing' AND its layer opacity, so a video is hidden (and fully quiescent - no decode, no GPU work) outside its window. Scaled-down reference for 'play A at 0:30, B at 1:05'-style scenes.",
  "nodes": [
    { "id": "seq", "type": "sequence", "duration": 12, "loop": true,
      "tracks": [
        { "name": "playA", "kind": "value", "type": "scalar", "interpolate": "hold",
          "keys": [ { "t": 0, "value": 0 }, { "t": 3, "value": 1 },
                    { "t": 6.5, "value": 0 } ] },
        { "name": "playB", "kind": "value", "type": "scalar", "interpolate": "hold",
          "keys": [ { "t": 0, "value": 0 }, { "t": 6.5, "value": 1 },
                    { "t": 11, "value": 0 } ] }
      ],
      "inputs": { "time": "@time.seconds" } },

    { "id": "vidA", "type": "video", "src": "assets/a.mp4",
      "inputs": { "playing": "@seq.playA" } },
    { "id": "vidB", "type": "video", "src": "assets/b.mp4",
      "inputs": { "playing": "@seq.playB" } },

    { "id": "placeA", "type": "transform",
      "inputs": { "source": "@vidA", "opacity": "@seq.playA" } },
    { "id": "placeB", "type": "transform",
      "inputs": { "source": "@vidB", "opacity": "@seq.playB" } },

    { "id": "comp", "type": "compositor",
      "inputs": { "layers": ["@placeA", "@placeB"] } },
    { "id": "out", "type": "output", "inputs": { "color": "@comp" } }
  ]
}
