{
  "version": 1,
  "name": "Effects",
  "description": "The effects library in one frame: the card contained, graded (slow hue drift) and glowing, over a cover-fit backdrop that is blurred then displaced by the card's own gradient — with a multiply-shaded gradient between them (§9.5 blend).",
  "packages": {
    "adjust": "1", "gradient": "1", "blur": "1", "glow": "1",
    "displace": "1"
  },
  "parameters": {
    "glowStrength": { "type": "scalar", "default": 0.8, "min": 0, "max": 3,
                      "label": "Glow" }
  },
  "nodes": [
    { "id": "card", "type": "image", "src": "assets/card.png" },
    { "id": "cover", "type": "fit", "inputs": { "source": "@card" } },
    { "id": "contain", "type": "fit", "mode": "contain",
      "inputs": { "source": "@card" } },

    { "id": "soft", "type": "graph", "graph": "packages/blur/graphs/blur.json",
      "inputs": { "source": "@cover", "radius": 6 } },
    { "id": "wavy", "type": "graph",
      "graph": "packages/displace/graphs/displace.json",
      "inputs": { "source": "@soft", "map": "@cover", "amount": 0.04 } },

    { "id": "shade", "type": "graph",
      "graph": "packages/gradient/graphs/gradient.json",
      "inputs": { "colorA": [1, 1, 1, 1], "colorB": [0.35, 0.32, 0.5, 1] } },

    { "id": "hueWave", "type": "wave",
      "inputs": { "input": "@time.seconds", "frequency": 0.05 } },
    { "id": "hue", "type": "remap",
      "inputs": { "value": "@hueWave", "inMin": -1, "inMax": 1,
                  "outMin": -40, "outMax": 40 } },
    { "id": "graded", "type": "graph",
      "graph": "packages/adjust/graphs/adjust.json",
      "inputs": { "source": "@contain", "saturation": 1.3,
                  "contrast": 1.1, "hue": "@hue" } },
    { "id": "lit", "type": "graph", "graph": "packages/glow/graphs/glow.json",
      "inputs": { "source": "@graded", "threshold": 0.5, "radius": 6,
                  "strength": "$glowStrength" } },

    { "id": "comp", "type": "compositor",
      "blend": ["over", "multiply", "over"],
      "inputs": { "layers": ["@wavy", "@shade", "@lit"] } },
    { "id": "out", "type": "output", "inputs": { "color": "@comp" } }
  ]
}
